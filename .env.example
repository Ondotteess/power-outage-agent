POSTGRES_USER=outage_agent
POSTGRES_PASSWORD=replace-this-password
POSTGRES_DB=outage_agent

# Used by local Python processes. Compose services override this to use host=db.
DATABASE_URL=postgresql+asyncpg://outage_agent:replace-this-password@localhost:5432/outage_agent

# Generic OpenAI-compatible LLM settings (DeepSeek baseline, not used by GigaChat normalizer).
LLM_BASE_URL=https://api.deepseek.com
LLM_API_KEY=
LLM_MODEL=deepseek-chat
LLM_NORMALIZATION_ENABLED=false
LLM_NORMALIZATION_MAX_PER_RAW=5
LLM_NORMALIZATION_RATE_PER_MINUTE=30

# GigaChat — address/event normalizer (Sber).
# Provide EITHER a single Authorization Key (base64 of "client_id:client_secret")
# OR Client ID + Client Secret separately — the client will base64-encode them for you.
GIGACHAT_AUTH_KEY=
GIGACHAT_CLIENT_ID=
GIGACHAT_CLIENT_SECRET=
GIGACHAT_SCOPE=GIGACHAT_API_PERS
GIGACHAT_BASE_URL=https://gigachat.devices.sberbank.ru/api/v1
GIGACHAT_OAUTH_URL=https://ngw.devices.sberbank.ru:9443/api/v2/oauth
GIGACHAT_MODEL=GigaChat-2
GIGACHAT_VERIFY_SSL=true

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

CORS_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# /api/offices/import shared secret. Leave blank for dev/pilot (endpoint will
# accept any caller). Set a strong value in production and pass it via
# `X-Import-Token: <value>` header.
OFFICE_IMPORT_TOKEN=

LOG_LEVEL=INFO
